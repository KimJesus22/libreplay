// Schema Prisma — fuente de verdad del modelo de datos (plan.md §4).
//
// Cada modelo llega con su fase: User (F1), Video (F2), Transcript (F4),
// embedding vector(1024) (F5)... F0 solo dejó la BD conectada y la extensión
// pgvector habilitada.

generator client {
  provider = "prisma-client-js"
  // postgresqlExtensions permite declarar extensiones aquí en vez de solo en
  // SQL crudo: prisma migrate las incluye en el diff y quedan versionadas.
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  // pgvector: una sola BD para datos relacionales Y vectores de búsqueda
  // semántica — decisión load-bearing de plan.md §2 (evita un segundo motor
  // tipo Pinecone/Qdrant que habría que operar y pagar).
  extensions = [vector]
}

// ---------------------------------------------------------------------------
// F1 — Auth y usuarios (plan.md §4, HU-01/HU-02)
// ---------------------------------------------------------------------------

enum Role {
  VIEWER
  UPLOADER
  ADMIN
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  // Hash argon2id del password — NUNCA el password en claro (plan.md §8).
  password  String
  role      Role     @default(VIEWER)
  // Hash del refresh token vigente. Guardar el hash (no el token) hace que
  // un dump de la BD no sirva para fabricar sesiones; sobreescribirlo en
  // cada /auth/refresh implementa la rotación: el token anterior deja de
  // validar. Una sola sesión activa por usuario — suficiente para F1; si en
  // el futuro hace falta multi-dispositivo, esto se extrae a su propia tabla.
  refreshTokenHash String?
  createdAt DateTime @default(now())
  videos    Video[]
  // Relaciones favorites/history llegan en F6 con sus modelos.
}

// ---------------------------------------------------------------------------
// F2 — Subida de videos (plan.md §4, HU-03)
// ---------------------------------------------------------------------------

// Categorías como enum CERRADO (decisión plan.md §5 y §10-riesgos: el LLM las
// elige de una lista fija en F5, no texto libre — evita "Comedia"/"comedia"/
// "Humor" como tres categorías distintas). El uploader puede ajustarlas a mano
// (PATCH) antes de publicar; en F5 el pipeline las sugiere solo. En español
// porque la interfaz es español (spec §7); i18n de etiquetas, fuera de scope.
enum Category {
  ANIMACION
  CINE
  DOCUMENTAL
  EDUCACION
  ENTRETENIMIENTO
  GAMING
  MUSICA
  NOTICIAS
  DEPORTES
  TECNOLOGIA
  OTRO
}

enum VideoStatus {
  // UPLOADING no estaba en el plan original (plan.md §4): existe porque entre
  // emitir la URL prefirmada y la confirmación del cliente, el objeto puede
  // no llegar nunca (tab cerrada, red caída). Sin este estado, esos registros
  // fantasma serían indistinguibles de videos reales en proceso.
  UPLOADING
  PROCESSING // pipeline IA corriendo (F4/F5)
  READY // listo para que el uploader revise y publique
  PUBLISHED
  HIDDEN // ocultado por un admin (F6)
  FAILED
}

model Video {
  id          String      @id @default(uuid())
  ownerId     String
  owner       User        @relation(fields: [ownerId], references: [id])
  title       String
  description String?
  // Clave del objeto en MinIO/R2 (`videos/<id>.mp4`). La BD guarda la
  // referencia, nunca los bytes — el video no pasa por la API (plan.md §3).
  storageKey  String      @unique
  // Tamaño DECLARADO al pedir la URL; /confirm lo coteja contra el objeto
  // real en storage. Int basta: el límite es 500 MB << 2^31.
  sizeBytes   Int
  status      VideoStatus @default(UPLOADING)
  // Categorías del video (F3): array del enum cerrado, vacío hasta que el
  // uploader o el pipeline (F5) las asignen. El catálogo filtra por `has`.
  categories  Category[]  @default([])
  // Contador de reproducciones (F3): lo incrementa GET /videos/:id/stream —
  // pedir la URL de streaming ≈ iniciar una reproducción. Ordena "populares".
  views       Int         @default(0)
  // Momento de publicación (F3): null mientras no esté PUBLISHED. El catálogo
  // ordena "recientes" por este campo, no por createdAt: un video subido hace
  // semanas y publicado hoy debe salir arriba.
  publishedAt DateTime?
  createdAt   DateTime    @default(now())
  // Campos IA (synopsis, tags, transcript, embedding, durationS) llegan con
  // F4/F5 — cada modelo con su fase.
}
