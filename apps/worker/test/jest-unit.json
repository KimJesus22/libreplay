{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": ".spec.ts$",
  "transform": {
    "^.+\\.ts$": ["ts-jest", { "tsconfig": "<rootDir>/../../tsconfig.json" }]
  },
  "moduleNameMapper": {
    "^@app/prisma$": "<rootDir>/../../libs/prisma/src",
    "^@app/storage$": "<rootDir>/../../libs/storage/src",
    "^@app/queue$": "<rootDir>/../../libs/queue/src",
    "^@app/ai$": "<rootDir>/../../libs/ai/src"
  }
}
