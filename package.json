{
  "name": "libreplay",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma de streaming de video con catalogación por IA — proyecto de portafolio",
  "packageManager": "pnpm@11.5.3+sha512.7ac1c919341c213a34dc0d02afb7143c5c26ac26ee8c4782deea821b8ac64d2134a081fd8941dae6e29bbb48f58dfc2b7fbceeccc07cb2f09d219d342a4969ed",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "nest build api && nest build worker",
    "start:api": "nest start api --watch",
    "start:api:prod": "node dist/apps/api/main",
    "start:worker": "nest start worker --watch",
    "start:worker:prod": "node dist/apps/worker/main",
    "lint": "eslint .",
    "format": "prettier --write \"{apps,libs}/**/*.ts\" \"*.{json,md,mjs}\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/terminus": "^10.2.3",
    "@prisma/client": "^6.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.1.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "eslint": "^9.10.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "prisma": "^6.1.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.5.0"
  }
}
