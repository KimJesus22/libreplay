{
  "name": "libreplay",
  "version": "0.6.0",
  "private": true,
  "description": "Plataforma de streaming de video con catalogación por IA — proyecto de portafolio",
  "packageManager": "pnpm@11.5.3+sha512.7ac1c919341c213a34dc0d02afb7143c5c26ac26ee8c4782deea821b8ac64d2134a081fd8941dae6e29bbb48f58dfc2b7fbceeccc07cb2f09d219d342a4969ed",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "nest build api && nest build worker",
    "start:api": "nest start api --watch",
    "start:api:prod": "node dist/apps/api/main",
    "start:worker": "nest start worker --watch",
    "start:worker:prod": "node dist/apps/worker/main",
    "lint": "eslint .",
    "format": "prettier --write \"{apps,libs}/**/*.ts\" \"*.{json,md,mjs}\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "test:unit": "jest --config apps/worker/test/jest-unit.json",
    "test:e2e": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config apps/api/test/jest-e2e.json --runInBand"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1066.0",
    "@aws-sdk/s3-request-presigner": "^3.1066.0",
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/terminus": "^10.2.3",
    "@prisma/client": "^6.1.0",
    "argon2": "^0.44.0",
    "bullmq": "^5.34.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.4.22",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.5.0",
    "@types/supertest": "^7.2.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.10.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^30.4.2",
    "prettier": "^3.3.3",
    "prisma": "^6.1.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.5.0"
  }
}
