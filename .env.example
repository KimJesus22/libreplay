# Copia este archivo a .env y ajusta valores. .env NUNCA se commitea.
# Recordatorio plan.md §6: el stack IA no usa API keys — esto es todo.

# --- API ---
PORT=3000

# --- PostgreSQL (los mismos valores que docker-compose.yml en dev) ---
DATABASE_URL=postgresql://libreplay:libreplay@localhost:5432/libreplay

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Almacenamiento S3: MinIO en dev, Cloudflare R2 en prod ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=libreplay
S3_SECRET_KEY=libreplay123
S3_BUCKET=videos

# --- Auth (F1) — generar uno real con: openssl rand -hex 32 ---
JWT_SECRET=cambiame-por-favor
