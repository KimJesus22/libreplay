# Copia este archivo a .env y ajusta valores. .env NUNCA se commitea.
# Recordatorio plan.md §6: el stack IA no usa API keys — esto es todo.

# --- API ---
PORT=3000

# --- PostgreSQL (los mismos valores que docker-compose.yml en dev) ---
DATABASE_URL=postgresql://libreplay:libreplay@localhost:5432/libreplay

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Almacenamiento S3: MinIO en dev, Cloudflare R2 en prod ---
S3_ENDPOINT=http://localhost:9000
# Solo si el endpoint que ve el cliente difiere del que ve la API (p. ej.
# API dentro de compose: interno http://minio:9000, público localhost:9000).
# Si se omite, las URLs se firman con S3_ENDPOINT.
# S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=libreplay
S3_SECRET_KEY=libreplay123
S3_BUCKET=videos
# Límite de subida en MB (default 500 — plan.md §8)
# MAX_VIDEO_SIZE_MB=500

# --- Transcripción / Whisper (F4) — lo consume el WORKER ---
# Contenedor faster-whisper. En compose es http://whisper:8081.
WHISPER_URL=http://localhost:8081
# Modelo de faster-whisper (se configura en el contenedor whisper, no aquí):
# tiny|base|small|medium|large-v3. Default `small` (plan.md §2).
# WHISPER_MODEL=small
# Timeout de la transcripción en ms (default 600000 = 10 min)
# WHISPER_TIMEOUT_MS=600000

# --- Ollama / IA (F5) — metadata (worker) + embeddings (worker y API) ---
# Servicio Ollama. En compose es http://ollama:11434.
OLLAMA_URL=http://localhost:11434
# Modelo del LLM de metadata (solo lo usa el worker). Default qwen2.5:3b-instruct.
# METADATA_MODEL=qwen2.5:3b-instruct
# Modelo de embeddings (worker y API). Default bge-m3 (1024 dims).
# EMBED_MODEL=bge-m3
# Timeout de las llamadas a Ollama en ms (default 120000 = 2 min)
# OLLAMA_TIMEOUT_MS=120000

# --- Auth (F1) — generar uno real con: openssl rand -hex 32 ---
JWT_SECRET=cambiame-por-favor

# --- Semilla admin (pnpm prisma:seed) — defaults solo para dev local ---
ADMIN_EMAIL=admin@libreplay.local
ADMIN_PASSWORD=admin-cambiame
